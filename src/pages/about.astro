---
import Layout from "../layouts/Layout.astro";
---
<Layout bodyClass="has-solid-header">
<main class="w-full bg-bg-off-white">
  <!-- Hero / page title spacing to account for fixed header -->
  <section class="pt-32 pb-14">
    <div class="mx-auto max-w-7xl px-6">
      <h1 class="mt-3 text-5xl md:text-6xl font-semibold text-black">
        Who Are WIE?
      </h1>
      <p class="mt-6 max-w-3/4 text-lg md:text-xl text-black/80 leading-relaxed">
        IEEE Women in Engineering (WIE) is the largest international professional
        organization dedicated to promoting women engineers and scientists and
        inspiring girls around the world to follow their academic interests to a
        career in engineering.
      </p>

      <div class="mt-2">
        <a
          href="https://wie.ieee.org/"
          target="_blank"
          rel="noreferrer"
          class="inline-flex items-center rounded-full bg-white text-black font-semibold py-2"
        >
          Learn more about IEEE WIE
        </a>
      </div>
    </div>
  </section>

  <!-- Mission -->
  <section class="pb-14">
    <div class="mx-auto max-w-7xl px-6">
      <div class="rounded-2xl border border-white/15 bg-black/25 backdrop-blur-md p-8 md:p-10">
        <h2 class="text-3xl md:text-4xl font-semibold text-white">Mission</h2>
        <p class="mt-5 text-lg text-white/80 leading-relaxed">
          The mission of IEEE WIE is to facilitate the global recruitment and retention
          of women in technical disciplines. IEEE WIE envisions a vibrant community of
          IEEE women and men collectively using their diverse talents to innovate for
          the benefit of humanity.
        </p>
      </div>
    </div>
  </section>

  <!-- Student Branches -->
  <section class="pb-16">
    <div class="mx-auto max-w-7xl px-6">
      <h2 class="text-3xl md:text-4xl font-semibold text-white">
        Ottawa Section Student Branches
      </h2>
      <p class="mt-4 max-w-3xl text-white/75">
        This website is run and maintained by the IEEE WIE Ottawa Section Student Branches.
      </p>

      <div class="mt-10 grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Carleton -->
        <div class="rounded-2xl border border-white/15 bg-black/25 backdrop-blur-md p-8">
          <div class="flex items-start justify-between gap-4">
            <h3 class="text-2xl font-semibold text-white">
              IEEE WIE Carleton University Student Branch
            </h3>
            <a
              href="https://www.ieeecarleton.ca/wie"
              target="_blank"
              rel="noreferrer"
              class="shrink-0 text-white/80 hover:text-white underline underline-offset-4"
            >
              Visit
            </a>
          </div>

          <dl class="mt-6 space-y-3 text-white/85">
            <div class="flex items-baseline justify-between gap-4">
              <dt class="font-semibold text-white">Chair</dt>
              <dd class="text-right">Avery Uyttewaal</dd>
            </div>
            <div class="flex items-baseline justify-between gap-4">
              <dt class="font-semibold text-white">Vice Chair</dt>
              <dd class="text-right">Vidhi Mudgal</dd>
            </div>
            <div class="flex items-baseline justify-between gap-4">
              <dt class="font-semibold text-white">External</dt>
              <dd class="text-right">Leah Hynes</dd>
            </div>
            <div class="flex items-baseline justify-between gap-4">
              <dt class="font-semibold text-white">Finance</dt>
              <dd class="text-right">Emily Aldridge</dd>
            </div>
            <div class="flex items-baseline justify-between gap-4">
              <dt class="font-semibold text-white">Internal</dt>
              <dd class="text-right">Lilly Egberts</dd>
            </div>
            <div class="flex items-baseline justify-between gap-4">
              <dt class="font-semibold text-white">Communications</dt>
              <dd class="text-right">Armeena Sajjad</dd>
            </div>
            <div class="flex items-baseline justify-between gap-4">
              <dt class="font-semibold text-white">Design</dt>
              <dd class="text-right">Remas Benamer</dd>
            </div>
            <div class="flex items-baseline justify-between gap-4">
              <dt class="font-semibold text-white">Graphics</dt>
              <dd class="text-right">Samyuktha Radhika</dd>
            </div>
            <div class="flex items-baseline justify-between gap-4">
              <dt class="font-semibold text-white">Social Media</dt>
              <dd class="text-right">Mansi Prajapati</dd>
            </div>
            <div class="flex items-baseline justify-between gap-4">
              <dt class="font-semibold text-white">Academics</dt>
              <dd class="text-right">Vivian Tran</dd>
            </div>
          </dl>
        </div>

        <!-- uOttawa -->
        <div class="rounded-2xl border border-white/15 bg-black/25 backdrop-blur-md p-8">
          <h3 class="text-2xl font-semibold text-white">
            IEEE WIE University of Ottawa Student Branch
          </h3>

          <dl class="mt-6 space-y-3 text-white/85">
            <div class="flex items-baseline justify-between gap-4">
              <dt class="font-semibold text-white">Chair</dt>
              <dd class="text-right">Somana Debnath</dd>
            </div>
            <div class="flex items-baseline justify-between gap-4">
              <dt class="font-semibold text-white">Vice Chair</dt>
              <dd class="text-right">Stuti Pandya</dd>
            </div>
            <div class="flex items-baseline justify-between gap-4">
              <dt class="font-semibold text-white">External</dt>
              <dd class="text-right">Krisha Veera</dd>
            </div>
            <div class="flex items-baseline justify-between gap-4">
              <dt class="font-semibold text-white">Finance</dt>
              <dd class="text-right">Luke Irvine</dd>
            </div>
            <div class="flex items-baseline justify-between gap-4">
              <dt class="font-semibold text-white">Internal</dt>
              <dd class="text-right">Chloe Dupont</dd>
            </div>
            <div class="flex items-baseline justify-between gap-4">
              <dt class="font-semibold text-white">Communications</dt>
              <dd class="text-right">Aurélie Dumas</dd>
            </div>
            <div class="flex items-baseline justify-between gap-4">
              <dt class="font-semibold text-white">Design</dt>
              <dd class="text-right">Zoe Saunders</dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </section>
</main>

</Layout>


        name: "Avery Uyttewaal",
    },
    {
        title: "Vice Chair",
        name: "Vidhi Mudgal",
    },
    {
        title: "External",
        name: "Leah Hynes",
    },
    {
        title: "Finance",
        name: "Emily Aldridge"
    },
    {
        title: "Internal",
        name: "Lilly Egberts",
    },
    {
        name: "Armeena Sajjad", 
        title: "Communications",

    },
    {
        title: "Design",
        name: "Remas Benamer",
    },
    {
        title: "Samyuktha Radhika",
        name: "Graphics",
    },
    {
        title: "Mansi Prajapati",
        name: "Social Media",
    },
    {
        title: "Vivian Tran",
        name: "Academics"
    },
]

const UOTTAWA = [
    {
        title: "Chair",
        name: "Somana Debnath",
    },
    {
        title: "Vice Chair",
        name: "Stuti Pandya",
    },
    {
        title: "External",
        name: "Krisha Veera",
    },

    {
        title: "Finance",
        name: "Luke Irvine",
    },
    {
        title: "Internal",
        name: "Chloe Dupont",
    },
    {
        title: "Communications",
        name: "Aurélie Dumas",

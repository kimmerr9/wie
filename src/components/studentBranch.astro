---
<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <Fragment>
        <div class="flex items-center justify-between gap-4">
            <h3 class="text-2xl font-semibold ">
                IEEE WIE Carleton University Student Branch
            </h3>
            <div class="text-base md:text-lg"><Underline content="Visit" href="https://www.ieeecarleton.ca/wie" /></div>
        </div>
        <dl class="mt-6 space-y-4">
            {CARLETON.map((student) => (
                <div class="flex items-baseline justify-between gap-4 text-base md:text-lg">
                    <dt class="font-semibold">{student.title}</dt>
                    <dd class="text-right">{student.name}</dd>
                </div>
            ))}
        </dl>
    </Fragment>
    <Fragment>
        <div class="flex items-center justify-between gap-4">
            <h3 class="text-2xl font-semibold ">
                IEEE WIE University of Ottawa Student Branch
            </h3>
            <div class="text-base md:text-lg"><Underline content="Visit" href="https://ieeeuottawa.ca/about/" /></div>
        </div>
        <dl class="mt-6 space-y-4">
            {UOTTAWA.map((student) => (
                <div class="flex items-baseline justify-between gap-4 text-base md:text-lg">
                    <dt class="font-semibold">{student.title}</dt>
                    <dd class="text-right">{student.name}</dd>
                </div>
            ))}
        </dl>
    </Fragment>
</div>
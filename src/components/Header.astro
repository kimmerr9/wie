---
import '../styles/global.css';
import Logo_BLK from '../assets/wie-logo-black.png';
---
<header class="fixed top-0 left-0 w-full z-50">
    <div class="mx-auto max-w-7xl">
        <div class="mt-5 flex items-center justify-between rounded-2xl border border-white/15 bg-black/25 backdrop-blur-md px-6 py-2.5">
            <a href="/" class="flex items-center gap-3">
                <img
                    src={Logo_BLK.src}
                    alt="IEEE WIE"
                    class="h-12 w-auto invert brightness-0"
                />
            </a>
            <ul class="hidden md:flex items-center gap-10 text-xl text-white/90">
                <li><a class="" href="/about">Who Are WIE</a></li>
                <li><a class="" href="">Patronage Package</a></li>
                <li><a class="" href="">Contact Us</a></li>
                <li><a class="ml-2 inline-flex items-center rounded-full bg-white text-black font-semibold px-5 py-2" href="">Buy Tickets</a></li>
            </ul>
        </div>
    </div>
</header>

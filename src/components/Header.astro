---
import '../styles/global.css';
import Logo_BLK from '../assets/wie-logo-black.png';
---
<header class="fixed top-0 left-0 w-full z-50">
    <div class="mx-auto max-w-7xl px-6">
        <button
            id="nav-backdrop"
            type="button"
            class="fixed inset-0 hidden md:hidden bg-transparent"
            aria-hidden="true"
            tabindex="-1"
        ></button>
        <div id="header-shell" class="mt-5 flex flex-wrap md:flex-nowrap items-center justify-between rounded-2xl border border-white/15 bg-black/25 backdrop-blur-md px-6 py-2.5">
            <a href="/" class="flex items-center gap-3 shrink-0">
                <img
                    src={Logo_BLK.src}
                    alt="IEEE WIE"
                    class="h-12 w-auto invert brightness-0"
                />
            </a>
            <ul class="hidden md:flex items-center flex-nowrap whitespace-nowrap gap-6 lg:gap-6 text-lg md:text-xl text-white/90">
                <li><a class="" href="/about">Who Are WIE</a></li>
                <li><a class="" href="/patronages">Patronage Package</a></li>
                <li><a class="" href="/contact">Contact Us</a></li>
                <li>
                    <a
                        class="ml-2 inline-flex items-center rounded-full bg-white text-black font-semibold px-5 py-2 hover:bg-white/90 transition"
                        href="/tickets"
                    >
                        Purchase Tickets
                    </a>
                </li>
            </ul>
            <!-- mobile hamburger -->
            <button
                id="nav-toggle"
                class="md:hidden inline-flex items-center justify-center rounded-xl p-2 text-white/90 hover:text-white hover:bg-white/10 transition"
                type="button"
                aria-label="Open menu"
                aria-controls="mobile-nav"
                aria-expanded="false"
            >
                <svg class="h-7 w-7" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
            </button>
            <!-- mobile dropdown -->
            <div id="nav-dropdown" class="md:hidden hidden w-full py-4">
                <nav class="flex flex-col gap-3 text-lg text-white/90">
                    <a 
                        class="rounded-xl px-3 py-2 hover:bg-white/10 transition" 
                        href="/about"
                    >
                        Who Are WIE
                    </a>
                    <a 
                        class="rounded-xl px-3 py-2 hover:bg-white/10 transition" 
                        href="/patronages"
                    >
                        Patronage Package
                    </a>
                    <a 
                        class="rounded-xl px-3 py-2 hover:bg-white/10 transition" 
                        href="/contact"
                    >
                        Contact Us
                    </a>
                    <a
                        class="mt-2"
                        href="/tickets"
                    >
                        <span class="text-black font-semibold bg-off-white rounded-full px-5 py-2">Purchase Tickets</span>
                    </a>
                </nav>
            </div>
        </div>
    </div>

    <script>
        const btn = document.getElementById('nav-toggle');
        const panel = document.getElementById('nav-dropdown');
        const backdrop = document.getElementById('nav-backdrop');
        const headerShell = document.getElementById('header-shell');

        function openMenu() {
            btn?.setAttribute('aria-expanded', 'true');
            btn?.setAttribute('aria-label', 'Close menu');

            panel?.classList.remove('hidden');
            backdrop?.classList.remove('hidden');

            // hide hamburger while menu is open
            btn?.classList.add('opacity-0', 'pointer-events-none');
        }

        function closeMenu() {
            btn?.setAttribute('aria-expanded', 'false');
            btn?.setAttribute('aria-label', 'Open menu');

            panel?.classList.add('hidden');
            backdrop?.classList.add('hidden');

            // show hamburger again
            btn?.classList.remove('opacity-0', 'pointer-events-none');
        }

        btn?.addEventListener('click', () => {
            const isOpen = btn.getAttribute('aria-expanded') === 'true';
            isOpen ? closeMenu() : openMenu();
        });

        // click anywhere outside the header closes it
        backdrop?.addEventListener('click', closeMenu);

        // extra safety: ONLY close when clicking outside the header,
        backdrop?.addEventListener('click', (e) => {
            if (!headerShell) return closeMenu();
            // If somehow the click is inside header, don't close
            const clickInsideHeader = headerShell.contains(e.target);
            if (!clickInsideHeader) closeMenu();
        });

        // close menu after clicking a mobile link
        panel?.querySelectorAll('a').forEach((link) => {
            link.addEventListener('click', closeMenu);
        });
    </script>
</header>

---
import '../styles/global.css';
import Logo_BLK from '../assets/wie-logo-black.png';
import Underline from './animations/hover/Underline.astro';
import Ripple from './animations/click/Ripple.astro';
import Opacity from './animations/hover/Opacity.astro';
import MobileNav from './animations/hover/mobileNav.astro';
---
<header class="fixed top-0 left-0 w-full z-50">
    <div class="mx-auto max-w-7xl px-6">
        <!-- return to current page mobile nav -->
        <button
            id="nav-backdrop"
            type="button"
            class="fixed inset-0 z-40 hidden lg:hidden bg-transparent"
            aria-hidden="true"
            tabindex="-1"
        ></button>

        <div id="header-shell" class="relative z-50 mt-5 flex flex-wrap lg:flex-nowrap items-center justify-between rounded-2xl border border-white/15 bg-off-black/25 backdrop-blur-md px-6 py-2.5">
            <!-- desktop header -->
            <Opacity img={Logo_BLK.src} href="/" alt="IEEE WIE Ottawa Section" />
            <ul class="hidden lg:flex items-center flex-nowrap whitespace-nowrap gap-8 text-lg lg:text-xl text-off-white">
                <li><Underline content="Who Are WIE" href="/about" duration="200"/></li>
                <li><Underline content="Patronage Package" href="/patronages" duration="300"/></li>
                <li><Underline content="Contact Us" href="/contact" duration="200"/></li>
                <li><Ripple content="Purchase Tickets" href="https://www.eventbrite.ca/e/wie-wine-cheese-2026-tickets-1875170919699" class="font-semibold" bg="off-white" text="off-black" /></li>
            </ul>

            <!-- mobile hamburger -->
             
            <button
                id="nav-toggle"
                class="lg:hidden inline-flex items-center justify-center rounded-xl p-2 text-off-white hover:text-off-white hover:bg-off-white/10 transition"
                type="button"
                aria-label="Open menu"
                aria-controls="mobile-nav"
                aria-expanded="false"
            >
                <svg class="h-7 w-7" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
            </button>

            <!-- mobile dropdown -->
             <!-- remove hover, links not working  -->
            <div id="nav-dropdown" class="lg:hidden hidden w-full py-4">
                <nav class="flex flex-col items-start gap-3 text-lg text-off-white">
                    <MobileNav content="Who Are WIE" href="/about" />
                    <MobileNav content="Patronage Package" href="/patronages" />
                    <MobileNav content="Contact Us" href="/contact" />
                    <Ripple content="Purchase Tickets" href="https://www.wikipedia.com" class="mt-2 font-semibold">
                </nav>
            </div>
        </div>
    </div>

    <script>
        const btn = document.getElementById('nav-toggle');
        const panel = document.getElementById('nav-dropdown');
        const backdrop = document.getElementById('nav-backdrop');
        const headerShell = document.getElementById('header-shell');

        function openMenu() {
            btn?.setAttribute('aria-expanded', 'true');
            btn?.setAttribute('aria-label', 'Close menu');

            panel?.classList.remove('hidden');
            backdrop?.classList.remove('hidden');

            // hide hamburger while menu is open
            btn?.classList.add('opacity-0', 'pointer-events-none');
        }

        function closeMenu() {
            btn?.setAttribute('aria-expanded', 'false');
            btn?.setAttribute('aria-label', 'Open menu');

            panel?.classList.add('hidden');
            backdrop?.classList.add('hidden');

            // show hamburger again
            btn?.classList.remove('opacity-0', 'pointer-events-none');
        }

        btn?.addEventListener('click', () => {
            const isOpen = btn.getAttribute('aria-expanded') === 'true';
            isOpen ? closeMenu() : openMenu();
        });

        // click anywhere outside the header closes it
        backdrop?.addEventListener('click', closeMenu);

        // extra safety: ONLY close when clicking outside the header
        // backdrop?.addEventListener('click', (e) => {
        //     if (!headerShell) return closeMenu();
        //     // if somehow the click is inside header -> don't close
        //     const clickInsideHeader = headerShell.contains(e.target);
        //     if (!clickInsideHeader) closeMenu();
        // });

        // close menu after clicking a mobile link
        panel?.querySelectorAll('a').forEach((link) => {
            link.addEventListener('click', closeMenu);
        });
    </script>
</header>

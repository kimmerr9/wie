---
const { content } = Astro.props;
const id = `wavy-${crypto.randomUUID()}`;
const chars = [...content];
---
<div id={id} class="wavy inline-flex">
  {chars.map((char) => (
    <span class="wavy-char text-xl">{char}</span>
  ))}
</div>
<script define:vars={{ id }}>
    const root = document.getElementById(id);
    if (!root) console.warn("Wavy: root not found", id);

    const spans = root ? [...root.querySelectorAll(".wavy-char")] : [];

    const clear = () => spans.forEach(s =>
        s.classList.remove("is-hover", "near-1", "near-2")
    );

    root?.addEventListener("pointerleave", clear);
    root?.addEventListener("pointerover", (e) => {
        const t = e.target;
        if (!(t instanceof HTMLElement) || !t.classList.contains("wavy-char")) return;

        clear();
        const i = spans.indexOf(t);
        if (i < 0) return;

        spans[i].classList.add("is-hover");
        spans[i - 1]?.classList.add("near-1");
        spans[i + 1]?.classList.add("near-1");
        spans[i - 2]?.classList.add("near-2");
        spans[i + 2]?.classList.add("near-2");
    });
</script>